# ===== DATABASE CONFIGURATION =====
# Neon PostgreSQL Database
# IMPORTANT: Use the pooler endpoint (with "-pooler-" in the hostname)
# This provides connection pooling and higher concurrency limits

DB_HOST=ep-broad-mud-amd05qxd-pooler.c-5.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=your_neon_password_here

# ===== JWT AUTHENTICATION =====
JWT_SECRET=your_jwt_secret_key_change_in_production

# ===== CORS CONFIGURATION =====
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,https://legacy-vault-nine.vercel.app

# ===== EMAIL CONFIGURATION (SendGrid) =====
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDER_EMAIL=your-email@example.com

# ===== ENVIRONMENT =====
# production | development | test
NODE_ENV=development
PORT=3000

# ===== DATABASE RESET (Development Only) =====
# Set to 'true' to reset the database on app startup (for testing)
# RESET_DB=false
